# Environment Variables Configuration
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/lolhighlights
MONGODB_TEST_URI=mongodb://localhost:27017/lolhighlights_test

# Riot Games API
RIOT_API_KEY=your-riot-api-key-here
RIOT_API_REGION=euw1

# Database Pool Configuration
DB_POOL_SIZE=10
DB_MIN_POOL_SIZE=2
DB_MAX_IDLE_TIME=30000
DB_CONNECT_TIMEOUT=10000

# JWT Configuration (for future authentication)
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=24h

# AI/ML Configuration (for highlight detection)
MODEL_PATH=./models/
HIGHLIGHT_THRESHOLD=0.75

# External Services
LOGS_API_KEY=your-logs-api-key-here
REDIS_URL=redis://localhost:6379